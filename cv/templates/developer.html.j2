<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{ personal.name }} — Résumé</title>
<style>
  @font-face{ font-family:'Plex'; font-weight:400; src:url({{ font('IBMPlexSans-Regular.ttf') }}) format('truetype'); }
  @font-face{ font-family:'Plex'; font-weight:500; src:url({{ font('IBMPlexSans-Medium.ttf') }}) format('truetype'); }
  @font-face{ font-family:'Plex'; font-weight:600; src:url({{ font('IBMPlexSans-SemiBold.ttf') }}) format('truetype'); }
  @font-face{ font-family:'Plex'; font-weight:700; src:url({{ font('IBMPlexSans-Bold.ttf') }}) format('truetype'); }
  @font-face{ font-family:'PlexMono'; font-weight:400; src:url({{ font('IBMPlexMono-Regular.ttf') }}) format('truetype'); }
  @font-face{ font-family:'PlexMono'; font-weight:500; src:url({{ font('IBMPlexMono-Medium.ttf') }}) format('truetype'); }

  :root{
    --side:#0f1f2e; --side2:#13273a; --side-ink:#eaf0f4; --side-muted:#93a7b6;
    --accent:#25d3b8; --accent-dk:#0f766e;
    --ink:#181b20; --muted:#5a616b; --faint:#8b929c; --hair:#e6e8ec;
    --sidew:2.45in;
  }
  @page{ size:Letter; margin:0; }
  *{ box-sizing:border-box; margin:0; padding:0; }
  html{
    -webkit-print-color-adjust:exact; print-color-adjust:exact;
    /* Paints the sidebar band on every page. */
    background:linear-gradient(90deg, var(--side) 0, var(--side) var(--sidew), #fff var(--sidew));
  }
  body{ font-family:'Plex', Arial, sans-serif; color:var(--ink); font-size:9.6pt; line-height:1.46; }
  a{ color:inherit; text-decoration:none; }

  .wrap{ display:flex; align-items:stretch; min-height:100%; }

  /* ---------- Sidebar ---------- */
  .side{ width:var(--sidew); flex:0 0 var(--sidew); background:var(--side); color:var(--side-ink);
         padding:0.4in 0.26in 0.35in; }
  .photo{ width:1.08in; height:1.08in; border-radius:50%; object-fit:cover; display:block;
          margin:0 auto 12px; border:2px solid var(--accent); }
  .side h3{ font-family:'PlexMono',monospace; font-size:7.4pt; font-weight:500; letter-spacing:1.5px;
            text-transform:uppercase; color:var(--accent); margin:11px 0 6px;
            padding-bottom:3px; border-bottom:1px solid rgba(255,255,255,.12); }
  .side h3:first-of-type{ margin-top:0; }

  .contact{ font-size:8.2pt; line-height:1.4; }
  .contact div{ color:var(--side-ink); word-break:break-word; }
  .contact .lbl{ color:var(--side-muted); font-family:'PlexMono',monospace; font-size:6.6pt;
                 letter-spacing:.5px; text-transform:uppercase; margin-top:4px; }
  .contact .lbl:first-child{ margin-top:0; }

  .skillgroup{ margin-bottom:6px; }
  .skillgroup .cat{ font-size:7.8pt; font-weight:600; color:var(--side-ink); margin-bottom:3px; }
  .tags{ display:flex; flex-wrap:wrap; gap:3px; }
  .tag{ font-family:'PlexMono',monospace; font-size:6.6pt; letter-spacing:.1px;
        color:#d6f5ee; background:rgba(37,211,184,.12); border:1px solid rgba(37,211,184,.35);
        border-radius:3px; padding:1px 4px; }

  .side .lang{ display:flex; justify-content:space-between; font-size:8.2pt; padding:1.5px 0; }
  .side .lang b{ font-weight:600; } .side .lang span{ color:var(--side-muted); }

  .side .edu{ font-size:8.4pt; margin-bottom:8px; }
  .side .edu .d{ font-weight:600; color:var(--side-ink); }
  .side .edu .i{ color:var(--side-muted); }
  .side .edu .y{ color:var(--accent); font-family:'PlexMono',monospace; font-size:7.4pt; }

  /* ---------- Main ---------- */
  .main{ flex:1; padding:0.42in 0.48in 0.34in 0.42in; }
  .name{ font-size:24pt; font-weight:700; letter-spacing:-.4px; line-height:1; color:var(--ink); }
  .role{ font-size:10.5pt; font-weight:500; color:var(--accent-dk); margin-top:4px; }

  .main h2{ font-size:9pt; font-weight:700; text-transform:uppercase; letter-spacing:1.5px;
            color:var(--ink); margin:12px 0 7px; padding-bottom:4px;
            border-bottom:2px solid var(--accent); display:inline-block; }
  section{ break-inside:avoid; }
  .summary{ font-size:9.6pt; line-height:1.45; color:#33383f; }

  .job{ margin-bottom:8px; break-inside:avoid; }
  .job-head{ display:flex; justify-content:space-between; align-items:baseline; gap:12px; }
  .job .r{ font-weight:600; font-size:10pt; color:var(--ink); }
  .job .c{ color:var(--accent-dk); font-weight:500; }
  .job .p{ font-family:'PlexMono',monospace; font-size:8pt; color:var(--faint); white-space:nowrap; }
  .job .s{ font-size:9.1pt; color:var(--muted); margin:1.5px 0 3px; }
  .job .tags .tag{ color:var(--accent-dk); background:rgba(15,118,110,.07);
                   border-color:rgba(15,118,110,.25); }

  .earlier{ font-size:9pt; }
  .earlier .er{ display:flex; justify-content:space-between; gap:12px; padding:2.5px 0;
                border-bottom:1px dotted var(--hair); }
  .earlier .er b{ font-weight:600; } .earlier .er span{ color:var(--muted); }
  .earlier .er .p{ font-family:'PlexMono',monospace; font-size:8pt; color:var(--faint); white-space:nowrap; }

  .footnote{ margin-top:13px; font-size:8.4pt; color:var(--faint); }
  .footnote a{ color:var(--accent-dk); }

  .langs-block{ break-inside:avoid; }
  .edu-row{ display:flex; justify-content:space-between; align-items:baseline; gap:12px; padding:3px 0; break-inside:avoid; }
  .edu-row .et{ font-size:9.4pt; } .edu-row .ei{ color:var(--muted); }
  .edu-row .p{ font-family:'PlexMono',monospace; font-size:8pt; color:var(--faint); white-space:nowrap; }
  h2{ break-after:avoid; }
</style>
</head>
<body>
<div class="wrap">

  <aside class="side">
    <img class="photo" src="{{ img(personal.photo) }}" alt="">

    <h3>Contact</h3>
    <div class="contact">
      <div class="lbl">Email</div><div><a href="mailto:{{ contact.email }}">{{ contact.email }}</a></div>
      <div class="lbl" style="margin-top:5px">Web</div><div><a href="{{ contact.website.url }}">{{ contact.website.label }}</a></div>
      <div class="lbl" style="margin-top:5px">GitHub</div><div><a href="{{ contact.github.url }}">{{ contact.github.label }}</a></div>
      <div class="lbl" style="margin-top:5px">LinkedIn</div><div><a href="{{ contact.linkedin.url }}">{{ contact.linkedin.label }}</a></div>
      <div class="lbl" style="margin-top:5px">Project</div><div><a href="{{ contact.project.url }}">{{ contact.project.label }}</a></div>
    </div>

    <h3>Skills</h3>
    {% for s in skills %}
    <div class="skillgroup">
      <div class="cat">{{ s.category }}</div>
      <div class="tags">{% for i in s.tags %}<span class="tag">{{ i }}</span>{% endfor %}</div>
    </div>
    {% endfor %}

    <div class="langs-block">
      <h3>Languages</h3>
      {% for l in languages %}
      <div class="lang"><b>{{ l.name }}</b><span>{{ l.level }}</span></div>
      {% endfor %}
    </div>
  </aside>

  <main class="main">
    <div class="name">{{ personal.name }}</div>
    <div class="role">{{ personal.headline }}</div>

    <section>
      <h2>Profile</h2>
      <p class="summary">{{ personal.summary_dev }}</p>
    </section>

    <section>
      <h2>Experience</h2>
      {% for x in experience[:6] %}
      <div class="job">
        <div class="job-head">
          <div class="r">{{ x.role }} <span class="c">· {{ x.org }}</span></div>
          <div class="p">{{ x.start }}&ndash;{{ x.end }}</div>
        </div>
        <div class="s">{{ x.summary }}</div>
        {% if x.stack %}<div class="tags">{% for i in x.stack %}<span class="tag">{{ i }}</span>{% endfor %}</div>{% endif %}
      </div>
      {% endfor %}

      {% if experience[6:] %}
      <div class="earlier">
        {% for x in experience[6:] %}
        <div class="er"><span><b>{{ x.role }}</b> · {{ x.org }}</span><span class="p">{{ x.start }}&ndash;{{ x.end }}</span></div>
        {% endfor %}
      </div>
      {% endif %}
    </section>

    <section>
      <h2>Education</h2>
      <div class="edu-main">
      {% for e in education if e.degree in ['D.Sc.', 'M.Sc.', 'B.Sc.'] %}
        <div class="edu-row">
          <div class="et"><b>{{ e.degree }}</b> · {{ e.field }} — <span class="ei">{{ e.institution }}</span></div>
          <div class="p">{{ e.start }}&ndash;{{ e.end }}</div>
        </div>
      {% endfor %}
      </div>
    </section>

    <div class="footnote">Full academic CV, publications and teaching record at
      <a href="{{ contact.website.url }}">{{ contact.website.label }}</a></div>
  </main>

</div>
</body>
</html>
